{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Naruto Arena Public Profile Record",
  "description": "Public profile facts only. Viewer-specific mission availability, unlock state, and other session data are out of scope for this schema.",
  "type": "object",
  "$defs": {
    "clanRef": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "./_common.schema.json#/$defs/nullableString"
        },
        "name": {
          "$ref": "./_common.schema.json#/$defs/nonEmptyString"
        },
        "abbreviation": {
          "$ref": "./_common.schema.json#/$defs/nullableString"
        },
        "url": {
          "$ref": "./_common.schema.json#/$defs/nullableCanonicalUrl"
        }
      },
      "required": [
        "name",
        "abbreviation",
        "url"
      ],
      "additionalProperties": false
    },
    "recentMatch": {
      "type": "object",
      "properties": {
        "match_id": {
          "$ref": "./_common.schema.json#/$defs/nullableString"
        },
        "mode": {
          "type": "string",
          "enum": [
            "ladder",
            "quick",
            "private",
            "unknown"
          ]
        },
        "result": {
          "type": "string",
          "enum": [
            "win",
            "loss",
            "draw",
            "unknown"
          ]
        },
        "opponent_id": {
          "$ref": "./_common.schema.json#/$defs/nullableString"
        },
        "opponent_name": {
          "$ref": "./_common.schema.json#/$defs/nullableString"
        },
        "played_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "replay_available": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "raw_text": {
          "$ref": "./_common.schema.json#/$defs/nullableString"
        }
      },
      "required": [
        "mode",
        "result",
        "opponent_id",
        "opponent_name",
        "played_at",
        "replay_available",
        "raw_text"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "id": {
      "$ref": "./_common.schema.json#/$defs/recordId"
    },
    "record_type": {
      "const": "profile_public"
    },
    "record_family": {
      "const": "public_fact"
    },
    "username": {
      "$ref": "./_common.schema.json#/$defs/nonEmptyString"
    },
    "display_name": {
      "$ref": "./_common.schema.json#/$defs/nullableString"
    },
    "profile_url": {
      "$ref": "./_common.schema.json#/$defs/nullableCanonicalUrl"
    },
    "clan": {
      "anyOf": [
        {
          "$ref": "#/$defs/clanRef"
        },
        {
          "type": "null"
        }
      ]
    },
    "stats": {
      "$ref": "./_common.schema.json#/$defs/statsBlock"
    },
    "recent_window_hours": {
      "$ref": "./_common.schema.json#/$defs/nullableInteger"
    },
    "recent_matches": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recentMatch"
      }
    },
    "source_refs": {
      "$ref": "./_common.schema.json#/$defs/sourceRefList"
    },
    "raw_text": {
      "$ref": "./_common.schema.json#/$defs/rawTextBlock"
    },
    "parse": {
      "$ref": "./_common.schema.json#/$defs/parseMeta"
    }
  },
  "required": [
    "id",
    "record_type",
    "record_family",
    "username",
    "clan",
    "stats",
    "recent_matches",
    "source_refs",
    "raw_text",
    "parse"
  ],
  "additionalProperties": false
}
